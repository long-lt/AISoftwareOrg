# ==============================================================================
# Unified AI Software Factory — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# LLM Provider Configuration
# ------------------------------------------------------------------------------
# Supported providers: openrouter, openai, gemini, ollama
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-v4-flash

# ------------------------------------------------------------------------------
# Per-Agent Model Overrides (optional — leave empty to use LLM_MODEL)
# ------------------------------------------------------------------------------
# DEV_MODEL=
# QA_MODEL=
# REVIEWER_MODEL=
# PM_MODEL=
# PLANNER_MODEL=

# ------------------------------------------------------------------------------
# LLM Routing Tiers (optional)
# ------------------------------------------------------------------------------
# FAST_LLM_MODEL=
# MEDIUM_LLM_MODEL=
# STRONG_LLM_MODEL=
# USE_LOCAL_LLM=false
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=codellama:7b

# ------------------------------------------------------------------------------
# Pipeline Settings
# ------------------------------------------------------------------------------
MAX_ATTEMPTS=3
MAX_REPAIR_ATTEMPTS=3
USE_DOCKER=false

# ------------------------------------------------------------------------------
# Dashboard & API Server
# ------------------------------------------------------------------------------
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_SECRET=change-me-to-a-random-string
ADMIN_API_KEY=change-me-admin-api-key
DASHBOARD_PASSWORD=
APP_ENV=development

# ------------------------------------------------------------------------------
# Job Queue
# ------------------------------------------------------------------------------
# Backend options: "thread" (Python threading) or "rq" (Redis Queue)
JOB_QUEUE_BACKEND=thread
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# Cost Management
# ------------------------------------------------------------------------------
DAILY_COST_LIMIT=5.00
