# ==========================================
# Unified AI Software Factory - .gitignore
# ==========================================

# 1. Python (Backend & Core)
# ------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Testing and Coverage
.cache/
.pytest_cache/
.coverage
.htmlcov/
htmlcov/
.nosexy
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# 2. Node.js & Vite (Frontend SPA)
# ------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/.eslintcache
frontend/.parcel-cache
frontend/.next/
frontend/out/
frontend/.svelte-kit/
frontend/build/

# 3. Mobile Workspace Sandbox (Generated Apps)
# ------------------------------------------
# Tránh đẩy mã nguồn sinh ra bởi agents lên git repository của framework chính
workspace/
!workspace/.gitkeep

# 4. Storage & Databases
# ------------------------------------------
# Không commit dữ liệu SQLite local, checkpoints, và bộ nhớ đệm
*.db
*.sqlite
*.sqlite3
storage/*.db
storage/*.sqlite
memory/*.db
memory/*.sqlite

# 5. Application Logs & Diagnostics
# ------------------------------------------
logs/
!logs/.gitkeep
*.log
reports/*.zip
reports/*.pdf

# 6. Environment Configurations (Security)
# ------------------------------------------
# Tuyệt đối không commit API keys và cấu hình bảo mật
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# 7. OS & System Artifacts
# ------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 8. Editor & IDE Settings
# ------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
